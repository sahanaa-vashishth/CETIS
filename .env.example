# Groq API Settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Settings (optional backup)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/cetis_db

# Redis
REDIS_URL=redis://localhost:6379

# App Settings
APP_NAME=CETIS
APP_VERSION=1.0.0
DEBUG=True

# Emotion Model
EMOTION_MODEL=j-hartmann/emotion-english-distilroberta-base

# Smoothing Factor for Emotional Memory
ALPHA=0.3